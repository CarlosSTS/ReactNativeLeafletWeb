    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-native": "5.0.0",
    "html-webpack-plugin": "5.6.6",
    "jest": "29.6.3",
    "prettier": "3.8.0",
    "react": "19.2.4",
